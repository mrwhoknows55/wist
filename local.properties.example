# Copy to `local.properties` (gitignored) and adjust. Gradle reads this for Android builds.
wist.api.baseUrl=https://api.wist.avadhut.dev
# Emulator hitting host machine:
# wist.api.baseUrl=http://10.0.2.2:8080

# Server Configuration
PORT=8080

# Firecrawl API
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/wist
DB_USER=postgres
DB_PASSWORD=postgres